# ─── Credenciais do app no John Deere Developer (developer.deere.com) ───
# Crie uma "Application" no portal e cole aqui:
JD_CLIENT_ID=
JD_CLIENT_SECRET=

# Redirect URI cadastrado no app da John Deere.
# Em desenvolvimento local use exatamente este valor (tem que bater com o portal):
JD_REDIRECT_URI=http://localhost:3000/oauth/callback

# Escopos necessários (não precisa mexer):
JD_SCOPES=ag1 ag2 ag3 eq1 eq2 org1 org2 offline_access

# ─── Comportamento do serviço ───
# MOCK=true  -> usa dados de exemplo (funciona SEM credenciais). Bom para testar o visual.
# MOCK=false -> puxa dados reais do Operations Center (precisa autorizar em /oauth/start).
MOCK=true

# Intervalo de polling em minutos (com que frequência consulta a API da JD).
POLL_MINUTOS=10

# Porta do servidor. Na nuvem, o provedor injeta PORT automaticamente — não fixe.
PORT=3000

# ID da organização no Operations Center. Deixe vazio para usar a primeira
# organização retornada pela API (o serviço loga qual encontrou no primeiro poll).
JD_ORG_ID=409551

# ─── Somente na NUVEM (deploy 24/7) ───
# URL pública do serviço (sem barra no fim). Usada nos redirects OAuth.
# Ex.: https://opc-bakaba.up.railway.app  (deixe vazio em local = usa localhost)
PUBLIC_URL=

# Diretório de estado persistente (tokens.json + snapshot.json). Aponte para o
# volume montado no provedor para não perder a autorização a cada restart.
# Ex.: STATE_DIR=/data   (deixe vazio em local = usa backend/data)
STATE_DIR=

# Semente do refresh_token para o primeiro boot na nuvem sem reautorizar.
# Copie o valor "refresh_token" de backend/data/tokens.json. Após o 1º refresh,
# o serviço grava tokens.json no STATE_DIR e passa a usar de lá.
JD_REFRESH_TOKEN=
